{
	"name": "bolt-rte",
	"description": "Professional Rich Text Editor for Directus with Multi-file Drag & Drop support",
	"icon": "edit_note",
	"version": "1.1.7",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-interface"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
		"type": "interface",
		"path": "dist/index.js",
		"source": "src/index.js",
		"host": "^10.10.0"
	},
	"scripts": {
		"build": "directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"validate": "directus-extension validate"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "17.1.0",
		"vue": "^3.5.31"
	},
	"dependencies": {
		"@tinymce/tinymce-vue": "^6.3.0",
		"tinymce": "^8.4.0"
	}
}
